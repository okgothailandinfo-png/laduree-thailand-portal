# Copy to .env and fill locally. Never commit real credentials.
#
# Local docker-compose example (after: docker compose up -d):
# DATABASE_URL="postgresql://laduree:laduree@127.0.0.1:5432/laduree_pickup?schema=public"
#
# APP_ENV:
#   development — mock providers allowed (default for local)
#   staging     — mock providers allowed when explicitly set
#   production  — fail-closed: prisma + real providers + HTTPS + secrets required
#
# Admin Product/Category CMS writes require:
#   DATA_SOURCE=prisma
#   DATABASE_URL=<postgres connection>
# Storefront APIs still work with DATA_SOURCE=mock for local UI work.

NODE_ENV=development
APP_ENV=development
APP_NAME=laduree-thailand-pickup
APP_BASE_URL=http://localhost:3000
APP_TIMEZONE=Asia/Bangkok
LOG_LEVEL=debug

DATABASE_URL=
DATA_SOURCE=mock

# Media binary upload (development/staging local storage only — not for production)
STORAGE_PROVIDER=local
MEDIA_MAX_FILE_SIZE_MB=10
MEDIA_LOCAL_UPLOAD_DIR=public/uploads

# Payment provider (mock only implemented — refused in production)
PAYMENT_PROVIDER=mock
# HMAC secret for POST /api/payment/webhook/mock (min 16 chars in staging/production)
MOCK_PAYMENT_WEBHOOK_SECRET=
# Optional timestamp skew tolerance in seconds (default 300)
MOCK_PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

# Pickup credential reveal encryption (min 16 chars in staging/production)
PICKUP_REVEAL_SECRET=

# Notification providers (mock only implemented — refused in production)
NOTIFICATION_EMAIL_PROVIDER=mock
NOTIFICATION_LINE_PROVIDER=mock
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_PROCESS_LIMIT=20
NOTIFICATION_BASE_URL=http://localhost:3000
# Optional: force mock provider failures for retry testing
# NOTIFICATION_MOCK_FORCE_FAILURE=true

# Rate limiting
# development/staging: memory
# production: redis required (client wiring is a Production Blocker)
RATE_LIMIT_STORE=memory
# REDIS_URL=
