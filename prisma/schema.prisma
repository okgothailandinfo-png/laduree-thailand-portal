// Ladurée Thailand Pickup — Prisma foundation (PostgreSQL)
// Schema only: not wired to APIs/services/repositories yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PLACED
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  PROMPTPAY_QR
  APPLE_PAY
  GOOGLE_PAY
}

enum PaymentStatus {
  PENDING
  MOCK_ACCEPTED
  FAILED
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([sortOrder])
  @@index([isActive])
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  categoryId   String   @db.Uuid
  slug         String   @unique
  sku          String   @unique
  title        String
  description  String[] @default([])
  storageLabel String?
  storageText  String?
  /// Thailand retail price in satang (minor units). Null until owner-approved.
  priceMinor   Int?
  currency     String   @default("THB") @db.Char(3)
  /// Catalog visibility (soft-deactivate without removing order history).
  isActive     Boolean  @default(true)
  /// Pickup availability for the storefront catalog.
  available    Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category   Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images     ProductImage[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([available])
  @@index([isActive])
  @@index([sortOrder])
}

/// Media library asset (URL-based and/or binary upload).
model Media {
  id               String   @id @default(uuid()) @db.Uuid
  /// Absolute http(s) URL or same-origin relative path.
  url              String
  altText          String?
  /// Optional CMS label for list/search (operational, not marketing copy).
  title            String?
  isActive         Boolean  @default(true)
  /// Client-supplied filename before sanitization (upload only).
  originalFileName String?
  /// Server-generated storage key / filename (upload only).
  fileName         String?
  mimeType         String?
  sizeBytes        Int?
  width            Int?
  height           Int?
  /// e.g. "local" for uploaded files; null for URL-only records.
  storageProvider  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productImages       ProductImage[]
  bannerDesktopImages HomepageBanner[] @relation("BannerDesktopImage")
  bannerMobileImages  HomepageBanner[] @relation("BannerMobileImage")

  @@index([isActive])
  @@index([createdAt])
  @@index([url])
  @@index([storageProvider])
}

enum HomepageContentType {
  plain_text
  multiline_text
  url
  boolean
}

/// Homepage hero / promotional banner. Images reference Media (no duplicated URLs).
model HomepageBanner {
  id                 String    @id @default(uuid()) @db.Uuid
  title              String
  subtitle           String?
  imageMediaId       String    @db.Uuid
  mobileImageMediaId String?   @db.Uuid
  linkUrl            String?
  linkLabel          String?
  sortOrder          Int       @default(0)
  isActive           Boolean   @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  imageMedia       Media  @relation("BannerDesktopImage", fields: [imageMediaId], references: [id], onDelete: Restrict)
  mobileImageMedia Media? @relation("BannerMobileImage", fields: [mobileImageMediaId], references: [id], onDelete: Restrict)

  @@index([sortOrder])
  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
  @@index([imageMediaId])
  @@index([mobileImageMediaId])
  @@index([isActive, sortOrder])
}

/// Configurable homepage section metadata (titles, visibility, order).
model HomepageSection {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  title       String?
  subtitle    String?
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@index([isActive, sortOrder])
}

/// Keyed homepage content values (announcement, intro, etc.). No HTML.
model HomepageContent {
  id          String              @id @default(uuid()) @db.Uuid
  key         String              @unique
  value       String
  contentType HomepageContentType
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([isActive])
  @@index([contentType])
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  mediaId   String   @db.Uuid
  /// Denormalized from Media.url for storefront read parity.
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([productId, sortOrder])
  @@index([productId, isPrimary])
  @@index([mediaId])
}

model Boutique {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  code          String   @unique
  address       String
  openingHours  String
  lastOrderTime String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pickupSlots PickupSlot[]
  orders      Order[]
}

model PickupSlot {
  id         String   @id @default(uuid()) @db.Uuid
  boutiqueId String   @db.Uuid
  /// Calendar day key in Asia/Bangkok, format YYYY-MM-DD
  dateKey    String
  startTime  String
  endTime    String
  label      String
  capacity   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  boutique Boutique @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@unique([boutiqueId, dateKey, startTime, endTime])
  @@index([boutiqueId, dateKey])
}

model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  customerName   String
  mobileNumber   String
  email          String
  recipientName  String?
  recipientPhone String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders Order[]

  @@unique([email, mobileNumber])
  @@index([email])
  @@index([mobileNumber])
}

model Order {
  id             String      @id @default(uuid()) @db.Uuid
  orderNumber    String      @unique
  status         OrderStatus @default(PENDING)
  customerId     String      @db.Uuid
  boutiqueId     String      @db.Uuid
  pickupSlotId   String      @db.Uuid
  currency       String      @default("THB") @db.Char(3)
  /// Order total in satang (minor units)
  totalMinor     Int         @default(0)
  specialRequest String?
  termsAccepted  Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  boutique           Boutique            @relation(fields: [boutiqueId], references: [id], onDelete: Restrict)
  pickupSlot         PickupSlot          @relation(fields: [pickupSlotId], references: [id], onDelete: Restrict)
  items              OrderItem[]
  payment            PaymentRecord?
  history            OrderHistory[]
  pickupVerification PickupVerification?
  notificationJobs   NotificationJob[]

  @@index([customerId])
  @@index([boutiqueId])
  @@index([pickupSlotId])
  @@index([status])
  @@index([createdAt])
}

/// Pickup check-in credentials. Raw QR tokens are never stored — only hashes.
/// customerRevealCipher holds AES-GCM ciphertext so the confirmation page can
/// re-display codes without regenerating on refresh.
model PickupVerification {
  id                   String    @id @default(uuid()) @db.Uuid
  orderId              String    @unique @db.Uuid
  pickupCodeHash       String    @unique
  tokenHash            String    @unique
  /// AES-256-GCM ciphertext of { token, pickupCode } for customer display only.
  customerRevealCipher String
  expiresAt            DateTime?
  verifiedAt           DateTime?
  verifiedBy           String?
  verificationAttempts Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([verifiedAt])
}

/// Audit trail for order status changes (admin and system).
model OrderHistory {
  id         String       @id @default(uuid()) @db.Uuid
  orderId    String       @db.Uuid
  fromStatus OrderStatus?
  toStatus   OrderStatus
  note       String?
  /// Actor identifier (e.g. mock-admin, system:payment). Never store secrets.
  changedBy  String?
  createdAt  DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@index([orderId, createdAt])
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @db.Uuid
  productId      String   @db.Uuid
  /// Snapshot of product title at order time
  productName    String
  quantity       Int
  /// Unit price snapshot in satang (minor units)
  unitPriceMinor Int
  currency       String   @default("THB") @db.Char(3)
  modifiers      Json?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model PaymentRecord {
  id          String        @id @default(uuid()) @db.Uuid
  orderId     String        @unique @db.Uuid
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  /// Charged amount in satang (minor units)
  amountMinor Int
  currency    String        @default("THB") @db.Char(3)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum NotificationChannel {
  EMAIL
  LINE
}

enum NotificationEventType {
  ORDER_CONFIRMED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  ORDER_PREPARING
  ORDER_READY_FOR_PICKUP
  ORDER_CANCELLED
  PICKUP_COMPLETED
}

enum NotificationJobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  SKIPPED
  DEAD
}

/// Database-backed notification delivery job (no Redis / external queue).
model NotificationJob {
  id             String                @id @default(uuid()) @db.Uuid
  eventType      NotificationEventType
  orderId        String?               @db.Uuid
  channel        NotificationChannel
  /// Recipient address or LINE user id. Mask in admin list views.
  recipient      String
  templateKey    String
  /// Structured template variables only — never secrets or full provider responses.
  payloadJson    Json
  status         NotificationJobStatus @default(PENDING)
  attemptCount   Int                   @default(0)
  maxAttempts    Int                   @default(3)
  scheduledAt    DateTime              @default(now())
  processedAt    DateTime?
  lastErrorCode  String?
  idempotencyKey String                @unique
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  order Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  logs  NotificationLog[]

  @@index([status, scheduledAt])
  @@index([orderId])
  @@index([eventType])
  @@index([channel])
  @@index([createdAt])
  @@index([status, createdAt])
}

/// Safe attempt audit for a notification job. Do not store message bodies.
model NotificationLog {
  id                String   @id @default(uuid()) @db.Uuid
  jobId             String   @db.Uuid
  provider          String
  providerMessageId String?
  status            String
  errorCode         String?
  attemptedAt       DateTime
  createdAt         DateTime @default(now())

  job NotificationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([attemptedAt])
  @@index([jobId, attemptedAt])
}

/// Channel / event enablement. key examples: channel.EMAIL, event.ORDER_CONFIRMED.
model NotificationSetting {
  id        String              @id @default(uuid()) @db.Uuid
  key       String              @unique
  channel   NotificationChannel
  isEnabled Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([channel])
  @@index([isEnabled])
}

/// Durable payment webhook idempotency (provider event ids).
model WebhookEvent {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @unique
  provider    String   @default("mock")
  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([processedAt])
  @@index([provider])
}

/// Admin / system audit trail. Safe metadata only — no secrets or PII payloads.
/// Transaction boundary: audit writes are best-effort AFTER the main operation
/// commits. Audit failure must not roll back the business mutation.
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  requestId    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([requestId])
}

/// Optional client idempotency keys for checkout / mutating public APIs.
model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  scope        String
  keyHash      String
  responseJson Json
  createdAt    DateTime @default(now())

  @@unique([scope, keyHash])
  @@index([createdAt])
}
